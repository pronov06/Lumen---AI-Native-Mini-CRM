# Copy to .env and adjust. docker-compose reads this automatically.

# Shared HMAC secret. The channel signs every callback with it; the CRM verifies.
# Must be identical on both services.
CALLBACK_SECRET=dev-shared-secret

# --- AI co-pilot ---------------------------------------------------------------
# Optional. Without a key the co-pilot uses the deterministic local planner, so
# the product is fully functional offline. With a key it calls OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# --- Channel simulator behaviour ----------------------------------------------
# Tune to make the live feed more or less hostile. Defaults are "realistic".
CHANNEL_FAILURE_RATE=0.06
CHANNEL_OUT_OF_ORDER_RATE=0.15
CHANNEL_DUPLICATE_RATE=0.08
CHANNEL_MIN_LATENCY_MS=150
CHANNEL_MAX_LATENCY_MS=1200

# --- Frontend (baked into the static bundle at build time) --------------------
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8000

# CORS origins the CRM accepts (comma-separated).
CRM_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
